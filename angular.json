{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "rais-component-library": {
      "projectType": "library",
      "root": "",
      "sourceRoot": "src",
      "prefix": "rais",
      "architect": {
        "storybook": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": ".storybook",
            "browserTarget": "rais-component-library:build",
            "compodoc": false,
            "port": 6006,
            "styles": [
              "node_modules/boxicons/css/boxicons.min.css",
              "src/index.css"
            ]
          }
        },
        "build-storybook": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "configDir": ".storybook",
            "browserTarget": "rais-component-library:build",
            "compodoc": false,
            "outputDir": "storybook-static",
            "styles": [
              "node_modules/boxicons/css/boxicons.min.css",
              "src/index.css"
            ]
          }
        },
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/rais-component-library",
            "index": "src/index.html",
            "main": "src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "assets": [
              { "glob": "**/*", "input": "public" }
            ],
            "styles": [
              "src/index.css"
            ],
            "scripts": []
          }
        }
      }
    }
  }
}
